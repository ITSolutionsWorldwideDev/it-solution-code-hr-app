generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  user_id       Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(50)
  email         String    @unique @db.VarChar(100)
  password_hash String    @db.VarChar(255)
  firstName     String?   @db.VarChar(50)
  lastName      String?   @db.VarChar(50)
  addr1         String?
  city          String?   @db.VarChar(150)
  zip           String?   @db.VarChar(100)
  country       String?   @db.VarChar(100)
  addrPhone     String?   @db.VarChar(200)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
  status        Int?      @default(1) @db.SmallInt

  blogs Blog[] @relation("UserBlogs")
  jobs  jobs_infos[] @relation("UserJobsInfos")

  @@index([email], map: "idx_users_email")
}

model Blog {
  id         Int      @id @default(autoincrement())
  title      String   @db.VarChar(255)
  slug       String   @unique @db.VarChar(255)
  content    String
  imageUrl   String?  @db.VarChar(500)
  published  Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  author_id Int
  author    users @relation(fields: [author_id], references: [user_id], name: "UserBlogs")

  @@index([slug], map: "idx_blog_slug")
  @@map("blogs")
}

model jobs_infos {
  job_info_id      Int       @id @default(autoincrement())
  title            String    @db.VarChar(255)
  location         String    @db.VarChar(255)
  type             String    @db.VarChar(100)
  content          String?
  pdf_url          String?
  hr_vacancy_id    Int?
  published        Int       @default(0) @db.SmallInt
  created_by       Int
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)
  author           users     @relation(fields: [created_by], references: [user_id], name: "UserJobsInfos")

  @@index([created_at], map: "idx_jobs_infos_created_at")
  @@index([published], map: "idx_jobs_infos_published")
}
